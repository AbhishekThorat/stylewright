{
  "name": "stylewright",
  "version": "0.1.0",
  "description": "Stylewright — a clean, modern browser extension for writing per-site CSS overrides.",
  "type": "module",
  "license": "MIT",
  "author": "Abhishek Thorat",
  "homepage": "https://github.com/abhishekthorat/stylewright",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhishekthorat/stylewright.git"
  },
  "bugs": {
    "url": "https://github.com/abhishekthorat/stylewright/issues"
  },
  "keywords": ["chrome-extension", "brave", "css", "userstyles", "manifest-v3", "wxt"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wxt",
    "icons": "node scripts/generate-icons.mjs",
    "build": "wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && npm run zip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.49.1",
    "@types/chrome": "^0.1.43",
    "chrome-webstore-upload-cli": "^4.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.36.1",
    "codemirror": "^6.0.1"
  }
}
